# Container registry (ECR or Docker Hub)
REGISTRY=022633198646.dkr.ecr.us-east-1.amazonaws.com/agentic-rl-bench
IMAGE_TAG=v1

# Result storage
S3_BUCKET=ec2-core-benchmark-ericyq
S3_PREFIX=agentic-rl-bench
AWS_REGION=us-east-1

# Test parameters
DURATION_SEC=300
# Concurrency sweep for B1/B3/B4/B5/B7. The high end is meant to
# saturate the workers' CPU on a 4xlarge - if you see <60% CPU even at
# 128, the worker is the bottleneck and the inner uvicorn-workers
# knob needs raising, not the client concurrency.
CONCURRENCIES=2,8,16,32,64,128

# Client load generator: how many child processes the orchestrator
# spawns to issue requests. 0 = auto = orchestrator vCPU count.
# A single asyncio loop tops out around 50-100k req/s; for B3/B7/B9
# at high concurrency we need multiple processes to actually drive
# the worker container's CPU to saturation. Override to a fixed
# number when you want a clean cross-arch comparison.
CLIENT_NPROCS=0
WARMUP_SEC=30
COOLDOWN_SEC=60

# Cost basis (USD per hour, On-Demand us-east-1, 4xlarge)
PRICE_C7I_4XL=0.7140
PRICE_C8G_4XL=0.6381

# B8 cold-start trial count
B8_TRIALS=1000

# B9 - end-to-end concurrent rollouts
# 30 min steady-state, ramp 64 -> 256 -> 1024
B9_DURATION_SEC=1800
B9_CONCURRENCIES=64,256,1024

# B5 - DuckDB TPC-H workload
# TPCH_SF: scale factor passed to dbgen. 1.0 ~ 6M lineitem rows / 500MB.
# Use 0.5 for faster smoke runs on smaller instances.
TPCH_SF=1.0
# DUCKDB_THREADS: 0 = auto (uses all container vCPUs).
DUCKDB_THREADS=0
# DUCKDB_MEM_LIMIT: empty = no explicit cap (DuckDB picks ~80% of RAM).
DUCKDB_MEM_LIMIT=

# B7 - text-game simulator
# Number of uvicorn worker processes. >= vCPU count saturates the
# container; reduce if comparing single-core latency only.
B7_UVICORN_WORKERS=8

# B3 - mock tool-call API
# auto = match container vCPU count (default). Override to a fixed
# integer if you want to compare e.g. 1-worker latency across archs.
B3_UVICORN_WORKERS=auto

# B4 - playwright headless Chromium.
# One uvicorn process per port (no SO_REUSEPORT) + client-side strict
# round-robin. Each worker process owns its own Chromium browser.
#
# B4_UVICORN_WORKERS:  auto = vCPU/2 (4xlarge -> 8, 16xlarge -> 32,
#                      24xlarge -> 48). Override only to clamp for
#                      cross-arch fairness (e.g. =8 on both archs).
# B4_MAX_CONTEXTS:     per-process BrowserContext pool size.
#                      0 = default 4. Total slots = WORKERS * MAX_CONTEXTS.
# B4_PORT_BASE:        first uvicorn port (default 8004). Workers
#                      occupy [base, base+WORKERS-1]. Change only if
#                      something else on the bench-net is squatting.
# B4_TRACE:            1 = per-trajectory action timing in worker stdout.
#                      Adds ~5us/action; KEEP OFF in production runs.
# B4_CONCURRENCIES:    sweep matched to instance size (worker slot count).
#                      4xlarge  (16 vCPU,  8 workers x 4 = 32 slots): 2,8,16,32,64,128
#                      16xlarge (64 vCPU, 32 workers x 4 = 128 slots): 2,16,64,128,256
#                      24xlarge (96 vCPU, 48 workers x 4 = 192 slots): 2,32,128,256,384
#                      Concurrencies > total-slots intentionally exercise
#                      pool queueing (rising pool_wait, p99). Below total-
#                      slots is "slack" - latency stays low, throughput
#                      scales linearly.
B4_UVICORN_WORKERS=auto
B4_MAX_CONTEXTS=0
B4_PORT_BASE=8004
B4_TRACE=0
B4_CONCURRENCIES=2,8,16,32,64,128

# B4 chromium debug flags (rare; leave at 0 unless investigating
# fork / IPC issues on a specific kernel version).
# CHROMIUM_DISABLE_DEV_SHM=0
# CHROMIUM_NO_ZYGOTE=0
# CHROMIUM_SINGLE_PROCESS=0

# Optional: skip specific benchmarks (comma-separated IDs)
# SKIP=B2,B6
